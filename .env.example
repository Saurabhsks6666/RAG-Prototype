# WATRANA RAG System - Environment Variables
# 
# STEP 1: Is file ki copy banao aur naam do: .env
# STEP 2: Apni OpenAI API key dalo niche
#
# HOW TO GET OPENAI API KEY:
# 1. Jao: https://platform.openai.com
# 2. Sign up / Login karo
# 3. Click karo: API Keys (left menu)
# 4. "Create new secret key" button dabao
# 5. Key copy karo aur yahan paste karo

OPENAI_API_KEY=your_openai_api_key_here

# Flask Settings (change nahi karna)
FLASK_SECRET_KEY=watrana-secret-2024
FLASK_DEBUG=True
